            </Ellipse>
            <Line startX="276" startY="325" endX="276" endY="363">
                <Stroke color="#D8B56A" thickness="1" />
            </Line>
            <Ellipse x="273.5" y="342.5" width="5" height="5">
                <Fill color="#D8B56A" />
            </Ellipse>
        </PartDraw>

        <PartImage x="110" y="305" width="28" height="23">
            <Image resource="steps_icon" />
        </PartImage>
        <PartImage x="215" y="303" width="20" height="29">
            <Image resource="battery_icon" />
        </PartImage>
        <PartImage x="314" y="305" width="24" height="21">
            <Image resource="heart_icon" />
        </PartImage>

        <PartText x="82" y="331" width="84" height="31">
            <Text align="CENTER" maxLines="1">
                <Font family="SYNC_TO_DEVICE" size="27" color="#FFFFFF" weight="LIGHT">
                    <Template><![CDATA[%,d]]>
                        <Parameter expression="[STEP_COUNT]" />
                    </Template>
                </Font>
            </Text>
        </PartText>

        <PartText x="183" y="331" width="84" height="31">
            <Text align="CENTER" maxLines="1">
                <Font family="SYNC_TO_DEVICE" size="27" color="#FFFFFF" weight="LIGHT">
                    <Template><![CDATA[%d%%]]>
                        <Parameter expression="[BATTERY_PERCENT]" />
                    </Template>
                </Font>
            </Text>
        </PartText>

        <PartText x="284" y="331" width="84" height="31">
            <Text align="CENTER" maxLines="1">
                <Font family="SYNC_TO_DEVICE" size="27" color="#FFFFFF" weight="LIGHT">
                    <Template><![CDATA[%.0f]]>
                        <Parameter expression="[HEART_RATE]" />
                    </Template>
                </Font>
            </Text>
        </PartText>

        <Condition>
            <Expressions>
                <Expression name="isFrench"><![CDATA[subText([LANGUAGE_LOCALE_NAME], 0, 2) == "fr"]]></Expression>
            </Expressions>
            <Compare expression="isFrench">
                <PartText x="88" y="356" width="72" height="21">
                    <Text align="CENTER" maxLines="1">
                        <Font family="SYNC_TO_DEVICE" size="13" color="#E9C579" weight="LIGHT">
                            <Template><![CDATA[PAS]]></Template>
                        </Font>
                    </Text>
                </PartText>
                <PartText x="187" y="356" width="76" height="21">
                    <Text align="CENTER" maxLines="1">
                        <Font family="SYNC_TO_DEVICE" size="13" color="#E9C579" weight="LIGHT">
                            <Template><![CDATA[BATTERIE]]></Template>
                        </Font>
                    </Text>
                </PartText>
                <PartText x="291" y="356" width="70" height="21">
                    <Text align="CENTER" maxLines="1">
                        <Font family="SYNC_TO_DEVICE" size="13" color="#E9C579" weight="LIGHT">
                            <Template><![CDATA[BPM]]></Template>
                        </Font>
                    </Text>
                </PartText>
            </Compare>
            <Default>
                <PartText x="88" y="356" width="72" height="21">
                    <Text align="CENTER" maxLines="1">
                        <Font family="SYNC_TO_DEVICE" size="13" color="#E9C579" weight="LIGHT">
                            <Template><![CDATA[STEPS]]></Template>
                        </Font>
                    </Text>
                </PartText>
                <PartText x="187" y="356" width="76" height="21">
                    <Text align="CENTER" maxLines="1">
                        <Font family="SYNC_TO_DEVICE" size="13" color="#E9C579" weight="LIGHT">
                            <Template><![CDATA[BATTERY]]></Template>
                        </Font>
                    </Text>
                </PartText>
                <PartText x="291" y="356" width="70" height="21">
                    <Text align="CENTER" maxLines="1">
                        <Font family="SYNC_TO_DEVICE" size="13" color="#E9C579" weight="LIGHT">
                            <Template><![CDATA[BPM]]></Template>
                        </Font>
                    </Text>
                </PartText>
            </Default>
        </Condition>

    </Scene>
</WatchFace>
