<?xml version="1.0" encoding="utf-8"?>
<WatchFace width="450" height="450" clipShape="CIRCLE">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:10:32" />
    <Metadata key="STEP_GOAL" value="10000" />

    <Scene>
        <PartDraw x="0" y="0" width="450" height="450">
            <Rectangle x="0" y="0" width="450" height="450">
                <Fill color="#000000">
                    <RadialGradient
                        centerX="225"
                        centerY="210"
                        radius="238"
                        colors="#FF201E1A #FF090807 #FF000000"
                        positions="0.0 0.58 1.0" />
                </Fill>
            </Rectangle>
            <Ellipse x="7" y="7" width="436" height="436">
                <Stroke color="#D8B56A" thickness="2.2" />
            </Ellipse>
            <Ellipse x="12" y="12" width="426" height="426">
                <Stroke color="#6B4F24" thickness="0.8" />
            </Ellipse>
        </PartDraw>

        <PartText x="62" y="64" width="326" height="44">
            <Localization />
            <Text align="CENTER" maxLines="1">
                <Font family="SYNC_TO_DEVICE" size="29" color="#E9C579" weight="LIGHT">
                    <Upper>
                        <Template><![CDATA[%s]]>
                            <Parameter expression="icuBestText(&quot;EEE MMM d&quot;)" />
                        </Template>
                    </Upper>
                </Font>
            </Text>
        </PartText>

        <DigitalClock x="0" y="92" width="450" height="160">
            <Localization timeZone="SYNC_TO_DEVICE" />
            <TimeText
                x="0"
                y="0"
                width="450"
                height="160"
                format="hh:mm"
                hourFormat="SYNC_TO_DEVICE"
                align="CENTER"
                hint="DIGITAL_CLOCK_TIME">
                <Font family="SYNC_TO_DEVICE" size="136" color="#FFF4DC" weight="MEDIUM" />
            </TimeText>
        </DigitalClock>

        <Condition>
            <Expressions>
                <Expression name="usesTwelveHour"><![CDATA[[IS_24_HOUR_MODE] == false]]></Expression>
            </Expressions>
            <Compare expression="usesTwelveHour">
                <PartText x="374" y="234" width="50" height="20">
                    <Localization />
                    <Text align="CENTER" maxLines="1">
                        <Font family="SYNC_TO_DEVICE" size="14" color="#E9C579" weight="LIGHT">
                            <Template><![CDATA[%s]]>
                                <Parameter expression="[AMPM_STRING]" />
                            </Template>
                        </Font>
                    </Text>
                </PartText>
            </Compare>
        </Condition>

        <PartDraw x="0" y="0" width="450" height="450">
            <Line startX="24" startY="260" endX="426" endY="260">
                <Stroke color="#C89D47" thickness="1.1" />
            </Line>
            <Ellipse x="221.5" y="257.5" width="7" height="7">
                <Fill color="#FFE1A0" />
            </Ellipse>
        </PartDraw>

        <ComplicationSlot
            x="105"
            y="232"
            width="240"
            height="58"
            slotId="22"
            supportedTypes="SHORT_TEXT"
            displayName="alarm_complication_name"
            isCustomizable="FALSE">
            <DefaultProviderPolicy
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="SHORT_TEXT"
                primaryProvider="com.cyberpat.luxurypixel.watchface.digital.preview/com.luxurypixel.watchface.WideNextAlarmComplicationDataSourceService"
                primaryProviderType="SHORT_TEXT" />
            <BoundingRoundBox x="0" y="0" width="240" height="58" cornerRadius="13" />
            <Complication type="SHORT_TEXT">
                <Group x="0" y="12" width="240" height="34" name="next_alarm_chip_wide" id="COMPLICATION.22" hint="COMPLICATION_SHORT_TEXT">
                    <PartDraw x="0" y="0" width="240" height="34">
                        <Rectangle x="0" y="0" width="240" height="34" cornerRadius="13">
                            <Fill color="#E8050504" />
                            <Stroke color="#96C89D47" thickness="0.7" />
                        </Rectangle>
                    </PartDraw>
                    <PartImage x="18" y="7" width="20" height="20">
                        <Image resource="alarm_icon" />
                    </PartImage>
                    <PartText x="44" y="1" width="180" height="32" name="next_alarm_text_wide" hint="TEXT">
                        <Text align="CENTER" maxLines="1" ellipsis="TRUE">
                            <Font family="SYNC_TO_DEVICE" size="24" color="#FFE1A0" weight="LIGHT">
                                <Template><![CDATA[%s]]>
                                    <Parameter expression="[COMPLICATION.TEXT]" />
                                </Template>
                            </Font>
                        </Text>
                    </PartText>
                </Group>
            </Complication>
        </ComplicationSlot>

        <ComplicationSlot
            x="151"
            y="232"
            width="148"
            height="58"
            slotId="21"
            supportedTypes="SHORT_TEXT"
            displayName="alarm_complication_name"
            isCustomizable="FALSE">
            <DefaultProviderPolicy
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="SHORT_TEXT"
                primaryProvider="com.cyberpat.luxurypixel.watchface.digital.preview/com.luxurypixel.watchface.NextAlarmComplicationDataSourceService"
                primaryProviderType="SHORT_TEXT" />
            <BoundingRoundBox x="0" y="0" width="148" height="58" cornerRadius="13" />
            <Complication type="SHORT_TEXT">
                <Group x="0" y="12" width="148" height="34" name="next_alarm_chip" id="COMPLICATION.21" hint="COMPLICATION_SHORT_TEXT">
                    <PartDraw x="0" y="0" width="148" height="34">
                        <Rectangle x="0" y="0" width="148" height="34" cornerRadius="13">
                            <Fill color="#E8050504" />
                            <Stroke color="#96C89D47" thickness="0.7" />
                        </Rectangle>
                    </PartDraw>
                    <PartImage x="18" y="7" width="20" height="20">
                        <Image resource="alarm_icon" />
                    </PartImage>
                    <PartText x="44" y="1" width="88" height="32" name="next_alarm_text" hint="TEXT">
                        <Text align="CENTER" maxLines="1" ellipsis="TRUE">
                            <Font family="SYNC_TO_DEVICE" size="24" color="#FFE1A0" weight="LIGHT">
                                <Template><![CDATA[%s]]>
                                    <Parameter expression="[COMPLICATION.TEXT]" />
                                </Template>
                            </Font>
                        </Text>
                    </PartText>
                </Group>
            </Complication>
        </ComplicationSlot>

        <Group x="105" y="244" width="240" height="34" name="next_alarm_tap_area">
            <TouchAction actionId="TAP_0" type="TAP" />
            <Launch target="ALARM" actionBy="TAP_0" />
            <PartDraw x="0" y="0" width="240" height="34" alpha="0">
                <Rectangle x="0" y="0" width="240" height="34" cornerRadius="13">
                    <Fill color="#00000000" />
